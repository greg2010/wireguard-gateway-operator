# Copy to .env and fill in. .env is gitignored — never commit it or any key.

# --- GCP project bootstrap (scripts/setup-gcp-project.sh + scripts/get-gcp-creds.sh) ---
GCP_PROJECT_ID=cyno-e2e-changeme
GCP_BILLING_ACCOUNT=XXXXXX-XXXXXX-XXXXXX   # required only when creating a new project
GCP_REGION=europe-west1
GCP_ZONE=europe-west1-b
CROSSPLANE_SA_NAME=crossplane              # provider-gcp service account (created by setup)
GCP_CREDS_FILE=.secrets/gcp-creds.json     # repo-relative; gitignored; never commit
# Namespace the creds Secret is loaded into (e2e harness + crossplane-config).
CROSSPLANE_NAMESPACE=crossplane-system
# Name of the creds Secret. Not used by get-gcp-creds.sh; consumed by the
# e2e harness + crossplane-config.
CROSSPLANE_CREDS_SECRET=gcp-creds
# --- cyno deploy / e2e (consumed later by the chart values + e2e harness) ---
# GATEWAY_DNS_HOSTNAMES=gateway.example.com    # external-dns hostnames -> gateway IP
